<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:paddingHorizontal="24dp"
    android:paddingTop="24dp"
    android:paddingBottom="24dp">

    <!-- TV Connection -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TV CONNECTION"
        android:textColor="#666688"
        android:textSize="11sp"
        android:letterSpacing="0.12"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TV IP Address"
        android:textColor="#AAAACC"
        android:textSize="13sp"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/edit_tv_ip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. 192.168.1.100"
        android:inputType="textUri"
        android:textColor="#FFFFFF"
        android:textColorHint="#444466"
        android:backgroundTint="#333355"
        android:padding="12dp"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btn_save"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_squircle_dark"
        android:text="Save"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold" />

</LinearLayout>
