<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/settings_root"
    android:tag="window_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="56dp">

        <TextView
            android:id="@+id/tv_settings_title"
            android:tag="title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold"
            android:paddingHorizontal="4dp"
            android:layout_marginBottom="32dp" />

        <!-- ─── TV CONNECTION ─── -->
        <TextView
            android:id="@+id/tv_section_connection"
            android:tag="section_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TV CONNECTION"
            android:textColor="#8E8E93"
            android:textSize="12sp"
            android:letterSpacing="0.06"
            android:paddingHorizontal="4dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/group_connection"
            android:tag="surface_bg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_section_group">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <TextView
                    android:tag="row_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IP Address"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/edit_tv_ip"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="end|center_vertical"
                    android:hint="192.168.1.x"
                    android:inputType="textUri"
                    android:textColor="#8E8E93"
                    android:textColorHint="#3A3A3A"
                    android:background="@null"
                    android:padding="0dp"
                    android:layout_marginStart="12dp"
                    android:textSize="15sp" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#242424" android:tag="divider" android:layout_marginStart="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <TextView
                    android:tag="row_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MAC Address"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/edit_tv_mac"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="end|center_vertical"
                    android:hint="AA:BB:CC:DD:EE:FF"
                    android:inputType="text"
                    android:textColor="#8E8E93"
                    android:textColorHint="#3A3A3A"
                    android:background="@null"
                    android:padding="0dp"
                    android:layout_marginStart="12dp"
                    android:textSize="15sp" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#242424" android:tag="divider" android:layout_marginStart="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp">

                <Button
                    android:id="@+id/btn_detect_mac"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_ghost"
                    android:text="Auto-detect MAC"
                    android:textColor="#8E8E93"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <View android:layout_width="10dp" android:layout_height="1dp" />

                <Button
                    android:id="@+id/btn_discover"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_accent"
                    android:text="Discover TV"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/discover_spinner"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="8dp"
                    android:visibility="gone"
                    android:indeterminateTint="#888888" />

            </LinearLayout>

        </LinearLayout>

        <!-- ─── CONTROLS ─── -->
        <TextView
            android:id="@+id/tv_section_controls"
            android:tag="section_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CONTROLS"
            android:textColor="#8E8E93"
            android:textSize="12sp"
            android:letterSpacing="0.06"
            android:paddingHorizontal="4dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/group_controls"
            android:tag="surface_bg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_section_group">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="12dp">

                <TextView
                    android:tag="row_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Volume slider"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <Switch
                    android:id="@+id/switch_vol_slider"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleX="1.2"
                    android:scaleY="1.2"
                    android:thumbTint="@color/switch_thumb"
                    android:trackTint="@color/switch_track" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#242424" android:tag="divider" android:layout_marginStart="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="12dp">

                <TextView
                    android:tag="row_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Brightness slider"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <Switch
                    android:id="@+id/switch_brightness_slider"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleX="1.2"
                    android:scaleY="1.2"
                    android:thumbTint="@color/switch_thumb"
                    android:trackTint="@color/switch_track" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#242424" android:tag="divider" android:layout_marginStart="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="12dp">

                <TextView
                    android:tag="row_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Channel buttons"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <Switch
                    android:id="@+id/switch_right_pill_channel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleX="1.2"
                    android:scaleY="1.2"
                    android:thumbTint="@color/switch_thumb"
                    android:trackTint="@color/switch_track" />

            </LinearLayout>

        </LinearLayout>

        <!-- ─── APP SHORTCUTS ─── -->
        <TextView
            android:id="@+id/tv_section_shortcuts"
            android:tag="section_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="APP SHORTCUTS"
            android:textColor="#8E8E93"
            android:textSize="12sp"
            android:letterSpacing="0.06"
            android:paddingHorizontal="4dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/group_shortcuts"
            android:tag="surface_bg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_section_group">

            <!-- Summary sits at top -->
            <TextView
                android:id="@+id/tv_shortcuts_summary"
                android:tag="section_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#8E8E93"
                android:textSize="13sp"
                android:paddingHorizontal="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp" />

            <!-- App grid expands inside the card when loaded -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/apps_grid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingBottom="8dp"
                android:nestedScrollingEnabled="false"
                android:visibility="gone" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#242424" android:tag="divider" android:layout_marginStart="16dp" />

            <!-- Load Apps — plain row action at the bottom -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingEnd="16dp">

                <Button
                    android:id="@+id/btn_load_apps"
                    android:tag="row_label"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackground"
                    android:text="Load Apps from TV"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="normal"
                    android:gravity="start|center_vertical"
                    android:paddingHorizontal="16dp"
                    android:drawableEnd="@drawable/ic_chevron_right"
                    android:drawableTint="#555555"
                    android:drawablePadding="4dp" />

                <ProgressBar
                    android:id="@+id/load_apps_spinner"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:visibility="gone"
                    android:indeterminateTint="#888888" />

            </LinearLayout>

        </LinearLayout>

        <!-- ─── APPEARANCE ─── -->
        <TextView
            android:id="@+id/tv_section_appearance"
            android:tag="section_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="APPEARANCE"
            android:textColor="#8E8E93"
            android:textSize="12sp"
            android:letterSpacing="0.06"
            android:paddingHorizontal="4dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/group_appearance"
            android:tag="surface_bg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_section_group">

            <LinearLayout
                android:id="@+id/row_theme"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:tag="row_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Theme"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tv_current_theme"
                    android:tag="row_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dark"
                    android:textColor="#8E8E93"
                    android:textSize="15sp"
                    android:layout_marginEnd="4dp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    android:scaleType="fitCenter"
                    android:tint="#555555" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#242424" android:tag="divider" android:layout_marginStart="16dp" />

            <LinearLayout
                android:id="@+id/row_create_theme"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:id="@+id/tv_create_theme"
                    android:tag="row_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Create Custom Theme"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    android:scaleType="fitCenter"
                    android:tint="#555555" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
