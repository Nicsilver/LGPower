<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

<ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="48dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LG TV Remote"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- TV connection status indicator -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <View
                android:id="@+id/status_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/status_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Checking…"
                android:textColor="#88FFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <!-- App shortcuts (populated dynamically from settings) -->
        <LinearLayout
            android:id="@+id/shortcuts_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <!-- Power + Keyboard -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/btn_power"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_circle_red"
                    android:src="@drawable/ic_power"
                    android:scaleType="center"
                    android:contentDescription="Power" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Power"
                    android:textColor="#AAAACC"
                    android:textSize="11sp"
                    android:layout_marginTop="5dp" />
            </LinearLayout>

            <Space android:layout_width="28dp" android:layout_height="1dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/btn_keyboard"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_circle_dark"
                    android:src="@drawable/ic_keyboard"
                    android:scaleType="center"
                    android:contentDescription="Keyboard" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Keyboard"
                    android:textColor="#AAAACC"
                    android:textSize="11sp"
                    android:layout_marginTop="5dp" />
            </LinearLayout>

            <Space android:layout_width="28dp" android:layout_height="1dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <FrameLayout
                    android:id="@+id/btn_touchpad"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:clickable="true"
                    android:focusable="true">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_circle_dark" />

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_touchpad"
                        android:scaleType="center"
                        android:contentDescription="Touchpad" />

                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Touchpad"
                    android:textColor="#AAAACC"
                    android:textSize="11sp"
                    android:layout_marginTop="5dp" />
            </LinearLayout>

        </LinearLayout>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <!-- D-pad + Volume pill -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Volume pill -->
            <FrameLayout
                android:layout_width="54dp"
                android:layout_height="230dp"
                android:background="@drawable/bg_pill_dark"
                android:clipToOutline="true">

                <!-- Fill bar — grows from bottom, height set programmatically -->
                <View
                    android:id="@+id/volume_bar"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_gravity="bottom"
                    android:background="#664FC3F7" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <ImageButton
                        android:id="@+id/btn_volume_up"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:src="@drawable/ic_volume_up"
                        android:scaleType="fitCenter"
                        android:padding="14dp"
                        android:contentDescription="Volume Up" />

                    <View
                        android:layout_width="34dp"
                        android:layout_height="1dp"
                        android:layout_gravity="center_horizontal"
                        android:background="#000000" />

                    <ImageButton
                        android:id="@+id/btn_volume_down"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:src="@drawable/ic_volume_down"
                        android:scaleType="fitCenter"
                        android:padding="14dp"
                        android:contentDescription="Volume Down" />

                </LinearLayout>

            </FrameLayout>

            <Space android:layout_width="10dp" android:layout_height="1dp" />

            <FrameLayout
                android:layout_width="230dp"
                android:layout_height="230dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_circle_dark" />

                <ImageButton
                    android:id="@+id/btn_up"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="4dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_arrow_up"
                    android:scaleType="centerInside"
                    android:contentDescription="Up" />

                <ImageButton
                    android:id="@+id/btn_down"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="4dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_arrow_down"
                    android:scaleType="centerInside"
                    android:contentDescription="Down" />

                <ImageButton
                    android:id="@+id/btn_left"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:layout_gravity="start|center_vertical"
                    android:layout_marginStart="4dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_arrow_left"
                    android:scaleType="centerInside"
                    android:contentDescription="Left" />

                <ImageButton
                    android:id="@+id/btn_right"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="4dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_arrow_right"
                    android:scaleType="centerInside"
                    android:contentDescription="Right" />

                <Button
                    android:id="@+id/btn_ok"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_circle_ok"
                    android:text="OK"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold" />

            </FrameLayout>

            <Space android:layout_width="10dp" android:layout_height="1dp" />

            <!-- Brightness pill (right) -->
            <FrameLayout
                android:layout_width="54dp"
                android:layout_height="230dp"
                android:background="@drawable/bg_pill_dark"
                android:clipToOutline="true">

                <!-- Fill bar — grows from bottom, height set programmatically -->
                <View
                    android:id="@+id/brightness_bar"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_gravity="bottom"
                    android:background="#44FFB74D" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <ImageButton
                        android:id="@+id/btn_brightness_up"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:src="@drawable/ic_brightness_up"
                        android:scaleType="fitCenter"
                        android:padding="14dp"
                        android:contentDescription="Brightness Up" />

                    <View
                        android:layout_width="34dp"
                        android:layout_height="1dp"
                        android:layout_gravity="center_horizontal"
                        android:background="#000000" />

                    <ImageButton
                        android:id="@+id/btn_brightness_down"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:src="@drawable/ic_brightness_down"
                        android:scaleType="fitCenter"
                        android:padding="14dp"
                        android:contentDescription="Brightness Down" />

                </LinearLayout>

            </FrameLayout>

        </LinearLayout>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <!-- Back + Screen Off + Settings + Mute -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/btn_back"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_circle_dark"
                    android:src="@drawable/ic_back"
                    android:scaleType="center"
                    android:contentDescription="Back" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Back"
                    android:textColor="#AAAACC"
                    android:textSize="11sp"
                    android:layout_marginTop="5dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/btn_screen_off"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_circle_dark"
                    android:src="@drawable/ic_screen_off"
                    android:scaleType="center"
                    android:contentDescription="Screen Off" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Screen Off"
                    android:textColor="#AAAACC"
                    android:textSize="11sp"
                    android:layout_marginTop="5dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/btn_settings"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_circle_dark"
                    android:src="@drawable/ic_settings"
                    android:scaleType="center"
                    android:contentDescription="Settings" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Settings"
                    android:textColor="#AAAACC"
                    android:textSize="11sp"
                    android:layout_marginTop="5dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/btn_mute"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_circle_dark"
                    android:src="@drawable/ic_mute"
                    android:scaleType="center"
                    android:contentDescription="Mute" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mute"
                    android:textColor="#AAAACC"
                    android:textSize="11sp"
                    android:layout_marginTop="5dp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>

<!-- App settings button — top-right corner -->
<ImageButton
    android:id="@+id/btn_app_settings"
    android:layout_width="44dp"
    android:layout_height="44dp"
    android:layout_gravity="top|end"
    android:layout_margin="8dp"
    android:background="@android:color/transparent"
    android:src="@drawable/ic_settings"
    android:scaleType="center"
    android:alpha="0.35"
    android:contentDescription="App Settings" />

<!-- Touchpad overlay — sits on top of everything, shown only during touchpad mode -->
<FrameLayout
    android:id="@+id/touchpad_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EE000000"
    android:visibility="gone">

    <!-- Growing border around the screen edge -->
    <com.nic.lgpower.LockBorderView
        android:id="@+id/lock_border"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <TextView
        android:id="@+id/touchpad_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="64dp"
        android:text="Drag to move cursor"
        android:textColor="#66FFFFFF"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btn_touchpad_exit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="24dp"
        android:background="@android:color/transparent"
        android:text="Exit"
        android:textColor="#E53935"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <Button
        android:id="@+id/btn_touchpad_click"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginStart="36dp"
        android:layout_marginEnd="36dp"
        android:layout_marginBottom="72dp"
        android:background="@drawable/bg_squircle_dark"
        android:text="Click"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

</FrameLayout>

</FrameLayout>
