<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.TRANSMIT_IR" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <uses-feature android:name="android.hardware.consumerir" android:required="false" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.LGRemote"
        android:usesCleartextTraffic="true">

        <!-- Main remote control activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- IR power widget trampoline -->
        <activity
            android:name=".IrActivity"
            android:exported="false"
            android:theme="@android:style/Theme.NoDisplay" />

        <!-- Screen off widget trampoline — uses Translucent so it can survive the network call -->
        <activity
            android:name=".ScreenOffActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!-- IR power widget -->
        <receiver
            android:name=".LGPowerWidget"
            android:exported="true"
            android:label="@string/widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

        <!-- OK/Enter widget -->
        <receiver
            android:name=".OkButtonWidget"
            android:exported="true"
            android:label="@string/ok_widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/ok_widget_info" />
        </receiver>

        <!-- Screen off widget -->
        <receiver
            android:name=".ScreenOffWidget"
            android:exported="true"
            android:label="@string/screen_off_widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/screen_off_widget_info" />
        </receiver>

    </application>
</manifest>
